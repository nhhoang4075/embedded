/* USER CODE BEGIN PTD */
struct Time {
    uint8_t sec;
    uint8_t min;
    uint8_t hour;
    uint8_t weekday;
    uint8_t day;
    uint8_t month;
    uint8_t year;
};

typedef struct {
    uint8_t id[5];
} Card;

typedef struct {
    struct Time time;
    uint8_t cardID[5];
} LogEntry;
/* USER CODE END PTD */

/* Private define ------------------------------------------------------------*/
/* USER CODE BEGIN PD */
#define MAX_CARDS    10
#define MAX_LOG      100
#define LED3_PIN     GPIO_PIN_13
#define LED4_PIN     GPIO_PIN_14
#define LED_PORT     GPIOG
/* USER CODE END PD */

/* Private macro -------------------------------------------------------------*/
/* USER CODE BEGIN PM */

/* USER CODE END PM */

