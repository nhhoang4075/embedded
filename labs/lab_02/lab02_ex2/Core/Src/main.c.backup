// ============= BCD helpers =============
uint8_t dec2bcd(uint8_t d) { return ((d / 10) << 4) | (d % 10); }
uint8_t bcd2dec(uint8_t b) { return (b >> 4) * 10 + (b & 0x0F); }

// ============= DS1307 =============
HAL_StatusTypeDef SetTime(struct Time *t) {
    struct Time bcd;
    bcd.sec = dec2bcd(t->sec);
    bcd.min = dec2bcd(t->min);
    bcd.hour = dec2bcd(t->hour);
    bcd.weekday = dec2bcd(t->weekday);
    bcd.day = dec2bcd(t->day);
    bcd.month = dec2bcd(t->month);
    bcd.year = dec2bcd(t->year);
    return HAL_I2C_Mem_Write(&hi2c3, 0xD0, 0, 1, (uint8_t *)&bcd, 7, 1000);
}

HAL_StatusTypeDef GetTime(struct Time *t) {
    struct Time bcd;
    HAL_StatusTypeDef s = HAL_I2C_Mem_Read(&hi2c3, 0xD1, 0, 1, (uint8_t *)&bcd, 7, 1000);
    t->sec = bcd2dec(bcd.sec);
    t->min = bcd2dec(bcd.min);
    t->hour = bcd2dec(bcd.hour);
    t->weekday = bcd2dec(bcd.weekday);
    t->day = bcd2dec(bcd.day);
    t->month = bcd2dec(bcd.month);
    t->year = bcd2dec(bcd.year);
    return s;
}

void SetInitialTime() {
    struct Time t;
    t.sec = 0; t.min = 30; t.hour = 15;
    t.day = 9; t.month = 5; t.year = 26; t.weekday = 0;
    SetTime(&t);
}

// ============= UART helpers =============
void uartPrint(const char *s) {
    HAL_UART_Transmit(&huart1, (uint8_t*)s, strlen(s), 1000);
}

// ============= Card helpers =============
int cardEqual(uint8_t *a, uint8_t *b) {
    return memcmp(a, b, 5) == 0;
}

int findCard(uint8_t *id) {
    for (uint8_t i = 0; i < whitelistCount; i++) {
        if (cardEqual(whitelist[i].id, id)) return i;
    }
    return -1;
}

// Parse "A3F21B0049" → 5 bytes. Returns 0 on success, -1 on error.
int parseHexID(const char *hex, uint8_t *out) {
    if (strlen(hex) != 10) return -1;
    for (int i = 0; i < 5; i++) {
        unsigned int b;
        char tmp[3] = { hex[i*2], hex[i*2+1], 0 };
        if (sscanf(tmp, "%02x", &b) != 1) return -1;
        out[i] = (uint8_t)b;
    }
    return 0;
}

void cardToHex(uint8_t *id, char *out) {
    sprintf(out, "%02X%02X%02X%02X%02X", id[0], id[1], id[2], id[3], id[4]);
}

// ============= Log =============
void addLog(struct Time *t, uint8_t *cardID) {
    if (logCount >= MAX_LOG) return;
    logs[logCount].time = *t;
    memcpy(logs[logCount].cardID, cardID, 5);
    logCount++;
}

// ============= UART command handlers =============
void cmdAdd(const char *arg) {
    char buf[80];
    uint8_t id[5];
    if (parseHexID(arg, id) != 0) {
        uartPrint("ERR: Invalid card ID (need 10 hex chars)\r\n");
        return;
    }
    if (findCard(id) >= 0) {
        uartPrint("ERR: Card already exists\r\n");
        return;
    }
    if (whitelistCount >= MAX_CARDS) {
        uartPrint("ERR: Whitelist full\r\n");
        return;
    }
    memcpy(whitelist[whitelistCount].id, id, 5);
    whitelistCount++;
    sprintf(buf, "OK: Card added (%d cards total)\r\n", whitelistCount);
    uartPrint(buf);
}

void cmdDel(const char *arg) {
    uint8_t id[5];
    if (parseHexID(arg, id) != 0) {
        uartPrint("ERR: Invalid card ID\r\n");
        return;
    }
    int idx = findCard(id);
    if (idx < 0) {
        uartPrint("ERR: Card not found\r\n");
        return;
    }
    for (int i = idx; i < whitelistCount - 1; i++) {
        whitelist[i] = whitelist[i+1];
    }
    whitelistCount--;
    uartPrint("OK: Card deleted\r\n");
}

void cmdList() {
    char buf[80];
    char hex[12];
    sprintf(buf, "Cards (%d):\r\n", whitelistCount);
    uartPrint(buf);
    for (uint8_t i = 0; i < whitelistCount; i++) {
        cardToHex(whitelist[i].id, hex);
        sprintf(buf, "%d. %s\r\n", i+1, hex);
        uartPrint(buf);
    }
}

void cmdLog() {
    char buf[100];
    char hex[12];
    sprintf(buf, "Log (%d entries):\r\n", logCount);
    uartPrint(buf);
    for (uint8_t i = 0; i < logCount; i++) {
        cardToHex(logs[i].cardID, hex);
        sprintf(buf, "%d. [%02d:%02d:%02d %02d/%02d/%02d] %s\r\n",
                i+1,
                logs[i].time.hour, logs[i].time.min, logs[i].time.sec,
                logs[i].time.day, logs[i].time.month, logs[i].time.year,
                hex);
        uartPrint(buf);
    }
}

void cmdHelp() {
    uartPrint("Commands:\r\n");
    uartPrint("  ADD <10 hex>  - add card to whitelist\r\n");
    uartPrint("  DEL <10 hex>  - remove card\r\n");
    uartPrint("  LIST          - list whitelist\r\n");
    uartPrint("  LOG           - show access log\r\n");
    uartPrint("  HELP          - this message\r\n");
}

void handleCommand(char *cmd) {
    // DEBUG: in ra raw command để check
    char dbg[80];
    sprintf(dbg, ">> Got cmd: '%s' (len=%d)\r\n", cmd, (int)strlen(cmd));
    uartPrint(dbg);

    // Bỏ khoảng trắng ở đầu
    while (*cmd == ' ') cmd++;

    if (strncasecmp(cmd, "ADD ", 4) == 0)       cmdAdd(cmd + 4);
    else if (strncasecmp(cmd, "DEL ", 4) == 0)  cmdDel(cmd + 4);
    else if (strcasecmp(cmd, "LIST") == 0)      cmdList();
    else if (strcasecmp(cmd, "LOG") == 0)       cmdLog();
    else if (strcasecmp(cmd, "HELP") == 0)      cmdHelp();
    else if (strlen(cmd) > 0)                   uartPrint("ERR: Unknown command. Type HELP\r\n");
}

volatile uint32_t rxByteCount = 0;
volatile uint32_t cmdReadyCount = 0;

// ============= UART RX interrupt =============
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
    if (huart->Instance == USART1) {
        rxByteCount++;
        if (rxByte == '\n' || rxByte == '\r') {
            if (rxIndex > 0) {
                rxBuffer[rxIndex] = '\0';
                strcpy(cmdBuffer, rxBuffer);
                cmdReady = 1;
                cmdReadyCount++;
                rxIndex = 0;
            }
        } else if (rxIndex < sizeof(rxBuffer) - 1) {
            rxBuffer[rxIndex++] = rxByte;
        }
        HAL_UART_Receive_IT(&huart1, (uint8_t*)&rxByte, 1);
    }
}

/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  */
int main(void)
{
    /* USER CODE BEGIN 1 */
    /* USER CODE END 1 */

    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_I2C3_Init();
    MX_SPI4_Init();
    MX_USART1_UART_Init();

    /* USER CODE BEGIN 2 */
    SetInitialTime();
    SH1106_Init();
    HAL_I2C_DeInit(&hi2c3);
    HAL_I2C_Init(&hi2c3);
    TM_MFRC522_Init();

    // Bắt đầu nhận UART theo ngắt
    HAL_UART_Receive_IT(&huart1, (uint8_t*)&rxByte, 1);

    // Tắt LED ban đầu
    HAL_GPIO_WritePin(LED_PORT, LED3_PIN, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(LED_PORT, LED4_PIN, GPIO_PIN_RESET);

    uartPrint("\r\n=== RFID Door System ===\r\n");
    cmdHelp();
    uartPrint("\r\n");
    /* USER CODE END 2 */

    /* USER CODE BEGIN WHILE */
    char buff[30];
    char dispBuf[20];
    struct Time t;
    uint8_t cardID[5];
    uint8_t lastCardPresent = 0;
    uint8_t noCardCounter = 0;
    char statusMsg[20] = "";

    uint32_t loopCount = 0;
    while (1) {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
        loopCount++;

        // DEBUG: in trạng thái mỗi 20 lần lặp (~3 giây)
        if (loopCount % 20 == 0) {
            char dbg[80];
            sprintf(dbg, "[debug] loop=%lu rxBytes=%lu cmdReady=%d cmdCnt=%lu rxIdx=%d\r\n",
                    loopCount, rxByteCount, cmdReady, cmdReadyCount, rxIndex);
            HAL_UART_Transmit(&huart1, (uint8_t*)dbg, strlen(dbg), 100);
        }

        // 1. Xử lý lệnh UART nếu có
        if (cmdReady) {
            cmdReady = 0;
            handleCommand(cmdBuffer);
        }

        // 2. Đọc thời gian
        GetTime(&t);

        // 3. Đọc thẻ RFID
        TM_MFRC522_Status_t st = TM_MFRC522_Check(cardID);

        if (st == MI_OK) {
            // Có thẻ
            HAL_GPIO_WritePin(LED_PORT, LED3_PIN, GPIO_PIN_SET);
            noCardCounter = 0;

            if (!lastCardPresent) {
                // Cạnh lên: thẻ mới được quẹt
                cardToHex(cardID, buff);

                if (findCard(cardID) >= 0) {
                    // Hợp lệ → mở khoá
                    HAL_GPIO_WritePin(LED_PORT, LED4_PIN, GPIO_PIN_SET);
                    strcpy(statusMsg, "Welcome");
                    addLog(&t, cardID);

                    char log[80];
                    sprintf(log, "[%02d:%02d:%02d] OPEN: %s\r\n",
                            t.hour, t.min, t.sec, buff);
                    uartPrint(log);
                } else {
                    // Không hợp lệ
                    HAL_GPIO_WritePin(LED_PORT, LED4_PIN, GPIO_PIN_RESET);
                    strcpy(statusMsg, "Rejected");

                    char log[80];
                    sprintf(log, "[%02d:%02d:%02d] DENY: %s\r\n",
                            t.hour, t.min, t.sec, buff);
                    uartPrint(log);
                }
            }
            lastCardPresent = 1;
        } else {
            // Không thấy thẻ — đợi vài lần để chắc chắn rút thẻ
            noCardCounter++;
            if (noCardCounter > 3) {
                HAL_GPIO_WritePin(LED_PORT, LED3_PIN, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(LED_PORT, LED4_PIN, GPIO_PIN_RESET);
                lastCardPresent = 0;
                statusMsg[0] = '\0';
            }
        }

        // 4. Hiển thị OLED
        sprintf(dispBuf, "%02d:%02d:%02d", t.hour, t.min, t.sec);
        SH1106_GotoXY(10, 0);
        SH1106_Puts(dispBuf, &Font_11x18, 1);

        sprintf(dispBuf, "%02d/%02d/%02d", t.day, t.month, t.year);
        SH1106_GotoXY(10, 20);
        SH1106_Puts(dispBuf, &Font_11x18, 1);

        // Status: Welcome / Rejected
        SH1106_GotoXY(10, 45);
        if (strlen(statusMsg) > 0) {
            SH1106_Puts(statusMsg, &Font_11x18, 1);
        } else {
            SH1106_Puts("          ", &Font_11x18, 1);  // xoá vùng status
        }

        SH1106_UpdateScreen();
        HAL_Delay(150);
    }
    /* USER CODE END 3 */
}

/**
  * @brief System Clock Configuration
  */
void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    __HAL_RCC_PWR_CLK_ENABLE();
    __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE1);

    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSI;
    RCC_OscInitStruct.HSIState = RCC_HSI_ON;
    RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
    RCC_OscInitStruct.PLL.PLLState = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource = RCC_PLLSOURCE_HSI;
    RCC_OscInitStruct.PLL.PLLM = 8;
    RCC_OscInitStruct.PLL.PLLN = 180;
    RCC_OscInitStruct.PLL.PLLP = RCC_PLLP_DIV2;
    RCC_OscInitStruct.PLL.PLLQ = 4;
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK) {
        Error_Handler();
    }

    if (HAL_PWREx_EnableOverDrive() != HAL_OK) {
        Error_Handler();
    }

    RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK|RCC_CLOCKTYPE_SYSCLK
                                |RCC_CLOCKTYPE_PCLK1|RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV4;
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV2;

    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_5) != HAL_OK) {
        Error_Handler();
    }
}

/**
  * @brief I2C3 Initialization Function
  */
static void MX_I2C3_Init(void)
{
    hi2c3.Instance = I2C3;
    hi2c3.Init.ClockSpeed = 100000;
    hi2c3.Init.DutyCycle = I2C_DUTYCYCLE_2;
    hi2c3.Init.OwnAddress1 = 0;
    hi2c3.Init.AddressingMode = I2C_ADDRESSINGMODE_7BIT;
    hi2c3.Init.DualAddressMode = I2C_DUALADDRESS_DISABLE;
    hi2c3.Init.OwnAddress2 = 0;
    hi2c3.Init.GeneralCallMode = I2C_GENERALCALL_DISABLE;
    hi2c3.Init.NoStretchMode = I2C_NOSTRETCH_DISABLE;
    if (HAL_I2C_Init(&hi2c3) != HAL_OK) {
        Error_Handler();
    }
    if (HAL_I2CEx_ConfigAnalogFilter(&hi2c3, I2C_ANALOGFILTER_ENABLE) != HAL_OK) {
        Error_Handler();
    }
    if (HAL_I2CEx_ConfigDigitalFilter(&hi2c3, 0) != HAL_OK) {
        Error_Handler();
    }
}

/**
  * @brief SPI4 Initialization Function
  */
static void MX_SPI4_Init(void)
{
    hspi4.Instance = SPI4;
    hspi4.Init.Mode = SPI_MODE_MASTER;
    hspi4.Init.Direction = SPI_DIRECTION_2LINES;
    hspi4.Init.DataSize = SPI_DATASIZE_8BIT;
    hspi4.Init.CLKPolarity = SPI_POLARITY_LOW;
    hspi4.Init.CLKPhase = SPI_PHASE_1EDGE;
    hspi4.Init.NSS = SPI_NSS_SOFT;
    hspi4.Init.BaudRatePrescaler = SPI_BAUDRATEPRESCALER_256;
    hspi4.Init.FirstBit = SPI_FIRSTBIT_MSB;
    hspi4.Init.TIMode = SPI_TIMODE_DISABLE;
    hspi4.Init.CRCCalculation = SPI_CRCCALCULATION_DISABLE;
    hspi4.Init.CRCPolynomial = 10;
    if (HAL_SPI_Init(&hspi4) != HAL_OK) {
        Error_Handler();
    }
}

/**
  * @brief USART1 Initialization Function
  */
static void MX_USART1_UART_Init(void)
{
    huart1.Instance = USART1;
    huart1.Init.BaudRate = 115200;
    huart1.Init.WordLength = UART_WORDLENGTH_8B;
    huart1.Init.StopBits = UART_STOPBITS_1;
    huart1.Init.Parity = UART_PARITY_NONE;
    huart1.Init.Mode = UART_MODE_TX_RX;
    huart1.Init.HwFlowCtl = UART_HWCONTROL_NONE;
    huart1.Init.OverSampling = UART_OVERSAMPLING_16;
    if (HAL_UART_Init(&huart1) != HAL_OK) {
        Error_Handler();
    }

    // Bật NVIC cho USART1 để dùng interrupt
    HAL_NVIC_SetPriority(USART1_IRQn, 5, 0);
    HAL_NVIC_EnableIRQ(USART1_IRQn);
}

/**
  * @brief GPIO Initialization Function
  */
