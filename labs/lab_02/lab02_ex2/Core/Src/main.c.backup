I2C_HandleTypeDef hi2c3;
SPI_HandleTypeDef hspi4;
UART_HandleTypeDef huart1;

/* USER CODE BEGIN PV */
Card whitelist[MAX_CARDS];
uint8_t whitelistCount = 0;

LogEntry logs[MAX_LOG];
uint8_t logCount = 0;

// UART RX
volatile uint8_t rxByte;
char rxBuffer[64];
volatile uint8_t rxIndex = 0;
volatile uint8_t cmdReady = 0;
char cmdBuffer[64];
/* USER CODE END PV */

